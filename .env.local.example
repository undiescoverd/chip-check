NEXT_PUBLIC_SUPABASE_URL=                    # client + server
NEXT_PUBLIC_SUPABASE_ANON_KEY=               # client, read-only
SUPABASE_SERVICE_ROLE_KEY=                   # SERVER ONLY — never prefix NEXT_PUBLIC_; used by write Route Handler
STAFF_PIN=                                   # server-side, validated in write Route Handler
NEXT_PUBLIC_READY_TIMEOUT_SECONDS=90         # how long ready orders stay on the display
